{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: Install",
      "type": "shell",
      "command": "bundle install",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Jekyll: Build",
      "type": "shell",
      "command": "bundle exec jekyll build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Jekyll: Serve",
      "type": "shell",
      "command": "bundle exec jekyll serve --livereload",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating...",
          "endsPattern": "Server running..."
        }
      }
    },
    {
      "label": "Jekyll: Serve with Drafts",
      "type": "shell",
      "command": "bundle exec jekyll serve --livereload --drafts",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating...",
          "endsPattern": "Server running..."
        }
      }
    }
  ]
}
